generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                    @id @default(cuid())
  name                      String?
  email                     String                    @unique
  emailVerified             Boolean                   @default(false)
  image                     String?
  password                  String?
  role                      String                    @default("employee")
  branchId                  String?
  departmentId              String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  accessProfileId           String?
  plan                      String?
  planExpireDate            DateTime?
  isActive                  Boolean                   @default(true)
  isEnableLogin             Boolean                   @default(true)
  accounts                  Account[]
  createdContracts          Contract[]
  conversationParticipants  ConversationParticipant[]
  createdCustomers          Customer[]                @relation("CreatedBy")
  employee                  Employee?
  createdLeads              Lead[]                    @relation("LeadCreatedBy")
  ownedLeads                Lead[]                    @relation("LeadOwner")
  loginDetails              LoginDetail[]
  messagesSent              Message[]
  orders                    Order[]
  sessions                  Session[]
  supportReplies            SupportReply[]
  assignedSupportTickets    SupportTicket[]           @relation("SupportAssignedTo")
  createdSupportTickets     SupportTicket[]           @relation("SupportCreatedBy")
  accessProfile             AccessProfile?            @relation(fields: [accessProfileId], references: [id])
  branch                    Branch?                   @relation(fields: [branchId], references: [id])
  department                Department?               @relation(fields: [departmentId], references: [id])
  createdVendors            Vendor[]
  zoomMeetingsCreated       ZoomMeeting[]             @relation("ZoomMeetingCreatedBy")
  zoomMeetingParticipations ZoomMeetingParticipant[]

  @@map("user")
}

model SupportTicket {
  id           String         @id @default(cuid())
  ticketCode   String         @unique
  subject      String
  description  String?
  attachment   String?
  status       String         @default("Open")
  priority     String         @default("Medium")
  endDate      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdById  String
  assignUserId String?
  replies      SupportReply[]
  assignUser   User?          @relation("SupportAssignedTo", fields: [assignUserId], references: [id])
  createdBy    User           @relation("SupportCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("support_ticket")
}

model SupportReply {
  id              String        @id @default(cuid())
  message         String
  createdAt       DateTime      @default(now())
  supportTicketId String
  userId          String
  supportTicket   SupportTicket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_reply")
}

/// Messenger: 1:1 conversations between users.
model Conversation {
  id           String                    @id @default(cuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversation")
}

model ConversationParticipant {
  id                String       @id @default(cuid())
  conversationId    String
  userId            String
  joinedAt          DateTime     @default(now())
  lastSeenMessageId String?
  lastSeenAt        DateTime?
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastSeenMessage   Message?     @relation("LastSeenMessage", fields: [lastSeenMessageId], references: [id])
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participant")
}

model Message {
  id             String                    @id @default(cuid())
  conversationId String
  senderId       String
  content        String                    @default("")
  createdAt      DateTime                  @default(now())
  lastSeenBy     ConversationParticipant[] @relation("LastSeenMessage")
  conversation   Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachments    MessageAttachment[]

  @@index([conversationId])
  @@index([senderId])
  @@map("message")
}

model MessageAttachment {
  id        String  @id @default(cuid())
  messageId String
  fileUrl   String
  fileName  String
  mimeType  String?
  fileSize  Int?
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachment")
}

/// Access profile per branch: name + permission set. Assignable to users (User.accessProfileId).
/// Distinct from User.role (user type: super admin, company, employee, client).
model AccessProfile {
  id          String   @id @default(cuid())
  name        String
  branchId    String
  permissions Json     @default("[]")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users       User[]

  @@index([branchId])
  @@map("access_profile")
}

model Branch {
  id                 String              @id @default(cuid())
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  address            String?
  email              String?
  logo               String?
  phone              String?
  website            String?
  accessProfiles     AccessProfile[]
  bankAccounts       BankAccount[]
  bankTransfers      BankTransfer[]
  barcodeSettings    BarcodeSetting[]
  bill               Bill[]
  budgetPlans        BudgetPlan[]
  categories         Category[]
  chartOfAccounts    ChartOfAccount[]
  customers          Customer[]
  deals              Deal[]
  departments        Department[]
  expenses           Expense[]
  financialGoals     FinancialGoal[]
  jobs               Job[]
  journalEntries     JournalEntry[]
  leads              Lead[]
  payments           Payment[]
  pipelines          Pipeline[]
  posOrders          PosOrder[]
  products           Product[]
  sources            Source[]
  users              User[]
  vendors            Vendor[]
  warehouses         Warehouse[]
  warehouseTransfers WarehouseTransfer[]

  @@map("branch")
}

model Department {
  id           String        @id @default(cuid())
  name         String
  branchId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  designations Designation[]
  users        User[]

  @@map("department")
}

model Designation {
  id            String         @id @default(cuid())
  name          String
  departmentId  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  hrmPromotions HrmPromotion[]

  @@map("designation")
}

model LeaveType {
  id            String         @id @default(cuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  daysPerYear   Int            @default(0)
  leaveRequests LeaveRequest[]

  @@map("leave_type")
}

model LeaveRequest {
  id          String    @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String    @default("Pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@index([leaveTypeId])
  @@map("leave_request")
}

model DocumentType {
  id            String   @id @default(cuid())
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  requiredField Boolean  @default(false)

  @@map("document_type")
}

model PayslipType {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payslips  Payslip[]

  @@map("payslip_type")
}

model Payslip {
  id                  String       @id @default(cuid())
  employeeId          String
  salaryMonth         String
  basicSalary         Float        @default(0)
  allowance           Float        @default(0)
  commission          Float        @default(0)
  loan                Float        @default(0)
  saturationDeduction Float        @default(0)
  otherPayment        Float        @default(0)
  overtime            Float        @default(0)
  netSalary           Float        @default(0)
  status              Int          @default(0)
  payslipTypeId       String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  employee            Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payslipType         PayslipType? @relation(fields: [payslipTypeId], references: [id])

  @@index([employeeId])
  @@index([salaryMonth])
  @@map("payslip")
}

model GoalType {
  id               String            @id @default(cuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  performanceGoals PerformanceGoal[]

  @@map("goal_type")
}

model TrainingType {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  trainings Training[]

  @@map("training_type")
}

/// Master data Trainer untuk modul Training HRM.
model Trainer {
  id        String     @id @default(cuid())
  branch    String
  firstName String
  lastName  String
  contact   String
  email     String     @unique
  expertise String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  trainings Training[]

  @@map("trainer")
}

/// Jadwal Training per karyawan.
model Training {
  id             String       @id @default(cuid())
  branch         String
  trainerOption  String
  trainingTypeId String
  employeeId     String
  trainerId      String
  status         String       @default("Pending")
  startDate      DateTime
  endDate        DateTime
  cost           Float        @default(0)
  description    String?
  performance    String?
  remarks        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employee       Employee     @relation(fields: [employeeId], references: [id])
  trainer        Trainer      @relation(fields: [trainerId], references: [id])
  trainingType   TrainingType @relation(fields: [trainingTypeId], references: [id])

  @@index([trainingTypeId])
  @@index([employeeId])
  @@index([trainerId])
  @@map("training")
}

model AwardType {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  awards    HrmAward[]

  @@map("award_type")
}

model TerminationType {
  id           String           @id @default(cuid())
  name         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  terminations HrmTermination[]

  @@map("termination_type")
}

/// HR Admin: Award records
model HrmAward {
  id          String    @id @default(cuid())
  employeeId  String
  awardTypeId String
  date        DateTime
  gift        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  awardType   AwardType @relation(fields: [awardTypeId], references: [id])
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([awardTypeId])
  @@map("hrm_award")
}

/// HR Admin: Transfer records
model HrmTransfer {
  id           String   @id @default(cuid())
  employeeId   String
  branch       String
  department   String
  transferDate DateTime
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("hrm_transfer")
}

/// HR Admin: Resignation records
model HrmResignation {
  id              String   @id @default(cuid())
  employeeId      String
  noticeDate      DateTime
  lastWorkingDate DateTime
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("hrm_resignation")
}

/// HR Admin: Travel/Trip records
model HrmTravel {
  id          String   @id @default(cuid())
  employeeId  String
  startDate   DateTime
  endDate     DateTime
  purpose     String
  country     String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("hrm_travel")
}

/// HR Admin: Promotion records
model HrmPromotion {
  id            String       @id @default(cuid())
  employeeId    String
  title         String
  promotionDate DateTime
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([designationId])
  @@map("hrm_promotion")
}

/// HR Admin: Complaint records
model HrmComplaint {
  id                 String   @id @default(cuid())
  employeeFromId     String
  complaintAgainstId String
  title              String
  date               DateTime
  description        String?
  status             String   @default("Pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  complaintAgainst   Employee @relation("ComplaintAgainst", fields: [complaintAgainstId], references: [id], onDelete: Cascade)
  employeeFrom       Employee @relation("ComplaintFrom", fields: [employeeFromId], references: [id], onDelete: Cascade)

  @@index([employeeFromId])
  @@index([complaintAgainstId])
  @@map("hrm_complaint")
}

/// HR Admin: Warning records
model HrmWarning {
  id          String   @id @default(cuid())
  employeeId  String
  warningById String
  subject     String
  warningDate DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation("WarningEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  warningBy   Employee @relation("WarningBy", fields: [warningById], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([warningById])
  @@map("hrm_warning")
}

/// HR Admin: Termination records
model HrmTermination {
  id                String          @id @default(cuid())
  employeeId        String
  terminationTypeId String
  noticeDate        DateTime
  terminationDate   DateTime
  description       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  terminationType   TerminationType @relation(fields: [terminationTypeId], references: [id])

  @@index([employeeId])
  @@index([terminationTypeId])
  @@map("hrm_termination")
}

/// HR Admin: Announcement records
model HrmAnnouncement {
  id          String    @id @default(cuid())
  title       String
  branch      String
  department  String
  startDate   DateTime
  endDate     DateTime
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("hrm_announcement")
}

/// HR Admin: Holiday records. DB still has legacy "date" column (NOT NULL) from initial migration.
model HrmHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  startDate   DateTime
  endDate     DateTime

  @@map("hrm_holiday")
}

/// HR: Company event records
model HrmEvent {
  id          String    @id @default(cuid())
  title       String
  branch      String
  department  String
  employeeId  String?
  startDate   DateTime
  endDate     DateTime
  color       String    @default("blue")
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("hrm_event")
}

model HrmMeeting {
  id          String   @id @default(cuid())
  title       String
  branch      String
  department  String
  employeeId  String
  meetingDate DateTime
  meetingTime String
  note        String?
  status      String   @default("Scheduled")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([meetingDate])
  @@map("hrm_meeting")
}

model JobCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("job_category")
}

model RecruitmentQuestion {
  id           String        @id @default(cuid())
  question     String
  isRequired   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobQuestions JobQuestion[]

  @@map("recruitment_question")
}

model Job {
  id            String           @id @default(cuid())
  title         String
  branchId      String
  jobCategoryId String
  positions     Int              @default(1)
  status        String           @default("active")
  startDate     DateTime
  endDate       DateTime
  description   String?
  requirement   String?
  skill         Json?
  applicant     Json?
  visibility    Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  branch        Branch           @relation(fields: [branchId], references: [id])
  jobCategory   JobCategory      @relation(fields: [jobCategoryId], references: [id])
  applications  JobApplication[]
  jobQuestions  JobQuestion[]

  @@map("job")
}

model JobQuestion {
  jobId      String
  questionId String
  order      Int                 @default(0)
  job        Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question   RecruitmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([jobId, questionId])
  @@map("job_question")
}

model JobApplication {
  id             String                 @id @default(cuid())
  jobId          String
  stageId        String
  applicantName  String
  email          String
  phone          String
  appliedDate    DateTime
  rating         Int                    @default(0)
  resume         String?
  coverLetter    String?
  isArchive      Boolean                @default(false)
  dob            String?
  gender         String?
  country        String?
  state          String?
  city           String?
  profile        String?
  skill          String?
  customQuestion Json?
  notes          Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  job            Job                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage          JobStage               @relation(fields: [stageId], references: [id])
  onboarding     JobOnboarding?
  interviews     RecruitmentInterview[]

  @@map("job_application")
}

model RecruitmentInterview {
  id            String         @id @default(cuid())
  applicationId String
  interviewDate DateTime
  interviewTime String
  interviewer   String
  location      String
  status        String         @default("Scheduled")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("recruitment_interview")
}

model JobStage {
  id           String           @id @default(cuid())
  name         String
  order        Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@map("job_stage")
}

/// Onboarding untuk kandidat yang sudah Hired. Link ke Application, optional ke Employee saat "convert to employee".
model JobOnboarding {
  id             String         @id @default(cuid())
  applicationId  String         @unique
  employeeId     String?        @unique
  status         String         @default("pending")
  onboardingDate DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  application    JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employee       Employee?      @relation(fields: [employeeId], references: [id])

  @@map("job_onboarding")
}

model PerformanceType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("performance_type")
}

model Competency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("competency")
}

/// Indikator performansi per branch/department/designation (rating teknis, organisasi, customer experience).
model PerformanceIndicator {
  id                       String   @id @default(cuid())
  branch                   String
  department               String
  designation              String
  technicalRating          Float
  organizationalRating     Float
  customerExperienceRating Float
  overallRating            Float
  addedBy                  String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  /// Periode indikator, mis. 2025 Q1
  periodYear               Int?
  periodQuarter            Int?

  @@unique([branch, department, designation, periodYear, periodQuarter], map: "performance_indicator_period_key")
  @@map("performance_indicator")
}

/// Appraisal per karyawan: target rating, overall rating, sub-rating, tanggal, remarks.
model PerformanceAppraisal {
  id                  String   @id @default(cuid())
  employeeId          String
  branch              String
  department          String
  designation         String
  targetRating        Float
  overallRating       Float
  appraisalDate       DateTime
  technicalRating     Float?
  leadershipRating    Float?
  teamworkRating      Float?
  communicationRating Float?
  remarks             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("performance_appraisal")
}

/// Goal tracking: link ke GoalType, subject, branch, target, periode, rating, progress.
model PerformanceGoal {
  id                String   @id @default(cuid())
  goalTypeId        String
  subject           String
  branch            String
  targetAchievement String
  startDate         DateTime
  endDate           DateTime
  rating            Int
  progress          Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  goalType          GoalType @relation(fields: [goalTypeId], references: [id])

  @@map("performance_goal")
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  date       DateTime
  status     String    @default("Present")
  clockIn    DateTime?
  clockOut   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance")
}

model Employee {
  id                    String                        @id @default(cuid())
  employeeId            String                        @unique
  name                  String
  email                 String                        @unique
  phone                 String
  dateOfBirth           DateTime
  gender                String
  address               String
  branch                String
  department            String
  designation           String
  dateOfJoining         DateTime
  lastLogin             DateTime?
  isActive              Boolean                       @default(true)
  salaryType            String?
  basicSalary           Float?
  documentsCertificate  String?
  documentsPhoto        String?
  accountHolderName     String?
  accountNumber         String?
  bankName              String?
  bankIdentifierCode    String?
  branchLocation        String?
  taxPayerId            String?
  userId                String?                       @unique
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  attendances           Attendance[]
  user                  User?                         @relation(fields: [userId], references: [id])
  allowances            EmployeeAllowance[]
  commissions           EmployeeCommission[]
  loans                 EmployeeLoan[]
  otherPayments         EmployeeOtherPayment[]
  overtimes             EmployeeOvertime[]
  saturationDeductions  EmployeeSaturationDeduction[]
  hrmAnnouncements      HrmAnnouncement[]
  hrm_asset_employees   hrm_asset_employees[]
  hrmAwards             HrmAward[]
  complaintsAgainst     HrmComplaint[]                @relation("ComplaintAgainst")
  complaintsFrom        HrmComplaint[]                @relation("ComplaintFrom")
  hrmEvents             HrmEvent[]
  hrmMeetings           HrmMeeting[]
  hrmPromotions         HrmPromotion[]
  hrmResignations       HrmResignation[]
  hrmTerminations       HrmTermination[]
  hrmTransfers          HrmTransfer[]
  hrmTravels            HrmTravel[]
  warningsReceived      HrmWarning[]                  @relation("WarningEmployee")
  warningsGiven         HrmWarning[]                  @relation("WarningBy")
  onboarding            JobOnboarding?
  leaveRequests         LeaveRequest[]
  payslips              Payslip[]
  performanceAppraisals PerformanceAppraisal[]
  trainings             Training[]

  @@map("employee")
}

model AllowanceOption {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  employeeAllowances EmployeeAllowance[]

  @@map("allowance_option")
}

model EmployeeAllowance {
  id                String          @id @default(cuid())
  employeeId        String
  allowanceOptionId String
  title             String
