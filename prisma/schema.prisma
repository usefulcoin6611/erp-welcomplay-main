generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String      @id @default(cuid())
  name             String?
  email            String      @unique
  emailVerified    Boolean     @default(false)
  image            String?
  password         String?
  role             String      @default("employee")
  branchId         String?
  departmentId     String?
  accessProfileId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  accounts         Account[]
  createdContracts Contract[]
  createdCustomers Customer[]  @relation("CreatedBy")
  accessProfile    AccessProfile? @relation(fields: [accessProfileId], references: [id], onDelete: SetNull)
  employee         Employee?
  createdLeads     Lead[]      @relation("LeadCreatedBy")
  ownedLeads       Lead[]      @relation("LeadOwner")
  sessions         Session[]
  loginDetails     LoginDetail[]
  branch           Branch?     @relation(fields: [branchId], references: [id])
  department       Department? @relation(fields: [departmentId], references: [id])
  createdVendors   Vendor[]
  createdSupportTickets SupportTicket[] @relation("SupportCreatedBy")
  assignedSupportTickets SupportTicket[] @relation("SupportAssignedTo")
  supportReplies   SupportReply[]

  @@map("user")
}

model SupportTicket {
  id          String    @id @default(cuid())
  ticketCode  String    @unique
  subject     String
  description String?
  attachment  String?
  status      String    @default("Open") // Open, On Hold, Close
  priority    String    @default("Medium") // Low, Medium, High, Critical
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String
  assignUserId String?
  createdBy   User      @relation("SupportCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  assignUser  User?     @relation("SupportAssignedTo", fields: [assignUserId], references: [id], onDelete: SetNull)
  replies     SupportReply[]

  @@map("support_ticket")
}

model SupportReply {
  id             String        @id @default(cuid())
  message        String
  createdAt      DateTime      @default(now())
  supportTicketId String
  userId         String
  supportTicket  SupportTicket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_reply")
}

/// Access profile per branch: name + permission set. Assignable to users (User.accessProfileId).
/// Distinct from User.role (user type: super admin, company, employee, client).
model AccessProfile {
  id          String   @id @default(cuid())
  name        String
  branchId    String
  permissions Json     @default("[]") // array of permission strings (REFERENCE_PERMISSIONS)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users       User[]

  @@map("access_profile")
  @@index([branchId])
}

model Branch {
  id              String           @id @default(cuid())
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bankAccounts    BankAccount[]
  bankTransfers   BankTransfer[]
  bill            Bill[]
  budgetPlans     BudgetPlan[]
  categories      Category[]
  chartOfAccounts ChartOfAccount[]
  customers       Customer[]
  deals           Deal[]
  departments     Department[]
  expenses        Expense[]
  financialGoals  FinancialGoal[]
  jobs            Job[]
  journalEntries  JournalEntry[]
  leads           Lead[]
  payments        Payment[]
  pipelines       Pipeline[]
  products        Product[]
  accessProfiles  AccessProfile[]
  users           User[]
  vendors         Vendor[]

  @@map("branch")
}

model Department {
  id           String        @id @default(cuid())
  name         String
  branchId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  designations Designation[]
  users        User[]

  @@map("department")
}

model Designation {
  id             String        @id @default(cuid())
  name           String
  departmentId   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  department     Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  hrmPromotions  HrmPromotion[]

  @@map("designation")
}

model LeaveType {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  daysPerYear Int      @default(0)

  leaveRequests LeaveRequest[]

  @@map("leave_type")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@map("leave_request")
  @@index([employeeId])
  @@index([leaveTypeId])
}

model DocumentType {
  id            String   @id @default(cuid())
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  requiredField Boolean  @default(false)

  @@map("document_type")
}

model PayslipType {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payslips  Payslip[]

  @@map("payslip_type")
}

model Payslip {
  id                  String      @id @default(cuid())
  employeeId          String
  salaryMonth         String      // YYYY-MM
  basicSalary         Float       @default(0)
  allowance           Float       @default(0)
  commission          Float       @default(0)
  loan                Float       @default(0)
  saturationDeduction Float      @default(0)
  otherPayment       Float       @default(0)
  overtime            Float       @default(0)
  netSalary           Float       @default(0)
  status              Int         @default(0) // 0 = Unpaid, 1 = Paid
  payslipTypeId       String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  employee            Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payslipType         PayslipType? @relation(fields: [payslipTypeId], references: [id], onDelete: SetNull)

  @@map("payslip")
  @@index([employeeId])
  @@index([salaryMonth])
}

model GoalType {
  id               String            @id @default(cuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  performanceGoals PerformanceGoal[]

  @@map("goal_type")
}

model TrainingType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainings Training[]

  @@map("training_type")
}

/// Master data Trainer untuk modul Training HRM.
model Trainer {
  id        String   @id @default(cuid())
  branch    String
  firstName String
  lastName  String
  contact   String
  email     String   @unique
  expertise String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trainer")

  trainings Training[]
}

/// Jadwal Training per karyawan.
model Training {
  id            String   @id @default(cuid())
  branch        String
  trainerOption String   // Internal | External
  trainingTypeId String
  employeeId    String
  trainerId     String
  status        String   @default("Pending") // Pending, Started, Completed, Terminated
  startDate     DateTime
  endDate       DateTime
  cost          Float    @default(0)
  description   String?
  performance   String?  // Not Concluded, Satisfactory, Average, Poor, Excellent
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trainingType TrainingType @relation(fields: [trainingTypeId], references: [id], onDelete: Restrict)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  trainer      Trainer      @relation(fields: [trainerId], references: [id], onDelete: Restrict)

  @@map("training")
  @@index([trainingTypeId])
  @@index([employeeId])
  @@index([trainerId])
}

model AwardType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  awards    HrmAward[]

  @@map("award_type")
}

model TerminationType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  terminations HrmTermination[]

  @@map("termination_type")
}

/// HR Admin: Award records
model HrmAward {
  id            String   @id @default(cuid())
  employeeId    String
  awardTypeId   String
  date          DateTime
  gift          String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  awardType  AwardType  @relation(fields: [awardTypeId], references: [id], onDelete: Restrict)

  @@map("hrm_award")
  @@index([employeeId])
  @@index([awardTypeId])
}

/// HR Admin: Transfer records
model HrmTransfer {
  id            String   @id @default(cuid())
  employeeId    String
  branch        String
  department    String
  transferDate  DateTime
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hrm_transfer")
  @@index([employeeId])
}

/// HR Admin: Resignation records
model HrmResignation {
  id              String   @id @default(cuid())
  employeeId      String
  noticeDate      DateTime
  lastWorkingDate DateTime
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hrm_resignation")
  @@index([employeeId])
}

/// HR Admin: Travel/Trip records
model HrmTravel {
  id          String   @id @default(cuid())
  employeeId  String
  startDate   DateTime
  endDate     DateTime
  purpose     String
  country     String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hrm_travel")
  @@index([employeeId])
}

/// HR Admin: Promotion records
model HrmPromotion {
  id             String    @id @default(cuid())
  employeeId     String
  designationId  String?
  title          String
  promotionDate  DateTime
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  designation  Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  @@map("hrm_promotion")
  @@index([employeeId])
  @@index([designationId])
}

/// HR Admin: Complaint records
model HrmComplaint {
  id               String   @id @default(cuid())
  employeeFromId   String
  complaintAgainstId String
  title            String
  date             DateTime
  description      String?
  status           String   @default("Pending") // Pending, In Progress, Resolved
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employeeFrom      Employee @relation("ComplaintFrom", fields: [employeeFromId], references: [id], onDelete: Cascade)
  complaintAgainst  Employee @relation("ComplaintAgainst", fields: [complaintAgainstId], references: [id], onDelete: Cascade)

  @@map("hrm_complaint")
  @@index([employeeFromId])
  @@index([complaintAgainstId])
}

/// HR Admin: Warning records
model HrmWarning {
  id          String   @id @default(cuid())
  employeeId  String
  warningById String
  subject     String
  warningDate DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee @relation("WarningEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  warningBy  Employee @relation("WarningBy", fields: [warningById], references: [id], onDelete: Cascade)

  @@map("hrm_warning")
  @@index([employeeId])
  @@index([warningById])
}

/// HR Admin: Termination records
model HrmTermination {
  id               String   @id @default(cuid())
  employeeId       String
  terminationTypeId String
  noticeDate       DateTime
  terminationDate  DateTime
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  terminationType TerminationType @relation(fields: [terminationTypeId], references: [id], onDelete: Restrict)

  @@map("hrm_termination")
  @@index([employeeId])
  @@index([terminationTypeId])
}

/// HR Admin: Announcement records
model HrmAnnouncement {
  id          String   @id @default(cuid())
  title       String
  branch      String
  department  String
  employeeId  String?
  startDate   DateTime
  endDate     DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@map("hrm_announcement")
  @@index([employeeId])
}

/// HR Admin: Holiday records. DB still has legacy "date" column (NOT NULL) from initial migration.
model HrmHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime // legacy column kept for DB compatibility; use startDate/endDate for range
  startDate   DateTime
  endDate     DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hrm_holiday")
}

/// HR: Company event records
model HrmEvent {
  id          String   @id @default(cuid())
  title       String
  branch      String
  department  String
  employeeId  String?
  startDate   DateTime
  endDate     DateTime
  color       String   @default("blue")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@map("hrm_event")
  @@index([employeeId])
}

model HrmMeeting {
  id           String   @id @default(cuid())
  title        String
  branch        String
  department    String
  employeeId    String
  meetingDate   DateTime
  meetingTime   String
  note         String?
  status       String   @default("Scheduled")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hrm_meeting")
  @@index([employeeId])
  @@index([meetingDate])
}

model JobCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("job_category")
}

model RecruitmentQuestion {
  id           String        @id @default(cuid())
  question     String
  isRequired   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobQuestions JobQuestion[]

  @@map("recruitment_question")
}

model Job {
  id            String           @id @default(cuid())
  title         String
  branchId      String
  jobCategoryId String
  positions     Int              @default(1)
  status        String           @default("active")
  startDate     DateTime
  endDate       DateTime
  description   String?
  requirement   String?
  skill         Json?
  applicant     Json?
  visibility    Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  branch        Branch           @relation(fields: [branchId], references: [id])
  jobCategory   JobCategory      @relation(fields: [jobCategoryId], references: [id])
  applications  JobApplication[]
  jobQuestions  JobQuestion[]

  @@map("job")
}

model JobQuestion {
  jobId      String
  questionId String
  order      Int                 @default(0)
  job        Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question   RecruitmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([jobId, questionId])
  @@map("job_question")
}

model JobApplication {
  id             String                 @id @default(cuid())
  jobId          String
  stageId        String
  applicantName  String
  email          String
  phone          String
  appliedDate    DateTime
  rating         Int                    @default(0)
  resume         String?
  coverLetter    String?
  isArchive      Boolean                @default(false)
  dob            String?
  gender         String?
  country        String?
  state          String?
  city           String?
  profile        String?
  skill          String?
  customQuestion Json?
  notes          Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  job            Job                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage          JobStage               @relation(fields: [stageId], references: [id])
  onboarding     JobOnboarding?
  interviews     RecruitmentInterview[]

  @@map("job_application")
}

model RecruitmentInterview {
  id            String         @id @default(cuid())
  applicationId String
  interviewDate DateTime
  interviewTime String
  interviewer   String
  location      String
  status        String         @default("Scheduled")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("recruitment_interview")
}

model JobStage {
  id           String           @id @default(cuid())
  name         String
  order        Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@map("job_stage")
}

/// Onboarding untuk kandidat yang sudah Hired. Link ke Application, optional ke Employee saat "convert to employee".
model JobOnboarding {
  id             String         @id @default(cuid())
  applicationId  String         @unique
  employeeId     String?        @unique
  status         String         @default("pending")
  onboardingDate DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  application    JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employee       Employee?      @relation(fields: [employeeId], references: [id])

  @@map("job_onboarding")
}

model PerformanceType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("performance_type")
}

model Competency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("competency")
}

/// Indikator performansi per branch/department/designation (rating teknis, organisasi, customer experience).
model PerformanceIndicator {
  id                       String   @id @default(cuid())
  branch                   String
  department               String
  designation              String
  technicalRating          Float
  organizationalRating     Float
  customerExperienceRating Float
  overallRating            Float
  addedBy                  String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  /// Periode indikator, mis. 2025 Q1
  periodYear               Int?
  periodQuarter            Int?

  @@unique([branch, department, designation, periodYear, periodQuarter], map: "performance_indicator_period_key")
  @@map("performance_indicator")
}

/// Appraisal per karyawan: target rating, overall rating, sub-rating, tanggal, remarks.
model PerformanceAppraisal {
  id                  String   @id @default(cuid())
  employeeId          String
  branch              String
  department          String
  designation         String
  targetRating        Float
  overallRating       Float
  appraisalDate       DateTime
  technicalRating     Float?
  leadershipRating    Float?
  teamworkRating      Float?
  communicationRating Float?
  remarks             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("performance_appraisal")
}

/// Goal tracking: link ke GoalType, subject, branch, target, periode, rating, progress.
model PerformanceGoal {
  id                String   @id @default(cuid())
  goalTypeId        String
  subject           String
  branch            String
  targetAchievement String
  startDate         DateTime
  endDate           DateTime
  rating            Int
  progress          Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  goalType          GoalType @relation(fields: [goalTypeId], references: [id])

  @@map("performance_goal")
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  date       DateTime
  status     String    @default("Present")
  clockIn    DateTime?
  clockOut   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance")
  @@index([employeeId])
  @@index([date])
}

model Employee {
  id                    String                 @id @default(cuid())
  employeeId            String                 @unique
  name                  String
  email                 String                 @unique
  phone                 String
  dateOfBirth           DateTime
  gender                String
  address               String
  branch                String
  department            String
  designation           String
  dateOfJoining         DateTime
  lastLogin             DateTime?
  isActive              Boolean                @default(true)
  salaryType            String?
  basicSalary           Float?
  documentsCertificate  String?
  documentsPhoto        String?
  accountHolderName     String?
  accountNumber         String?
  bankName              String?
  bankIdentifierCode    String?
  branchLocation        String?
  taxPayerId            String?
  userId                String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                     User?                        @relation(fields: [userId], references: [id])
  onboarding               JobOnboarding?
  performanceAppraisals    PerformanceAppraisal[]
  trainings                Training[]
  leaveRequests            LeaveRequest[]
  allowances               EmployeeAllowance[]
  commissions              EmployeeCommission[]
  loans                    EmployeeLoan[]
  saturationDeductions     EmployeeSaturationDeduction[]
  otherPayments            EmployeeOtherPayment[]
  overtimes                EmployeeOvertime[]
  hrmAwards                HrmAward[]
  hrmTransfers             HrmTransfer[]
  hrmResignations          HrmResignation[]
  hrmTravels               HrmTravel[]
  hrmPromotions            HrmPromotion[]
  hrmEvents                HrmEvent[]
  hrmMeetings              HrmMeeting[]
  hrmAnnouncements         HrmAnnouncement[]
  complaintsFrom           HrmComplaint[]  @relation("ComplaintFrom")
  complaintsAgainst        HrmComplaint[]  @relation("ComplaintAgainst")
  warningsReceived         HrmWarning[]     @relation("WarningEmployee")
  warningsGiven            HrmWarning[]    @relation("WarningBy")
  hrmTerminations          HrmTermination[]
  payslips                 Payslip[]
  attendances              Attendance[]

  @@map("employee")
}

model AllowanceOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employeeAllowances EmployeeAllowance[]

  @@map("allowance_option")
}

model EmployeeAllowance {
  id                String   @id @default(cuid())
  employeeId        String
  allowanceOptionId String
  title             String
  amount            Float    @default(0)
  type              String   @default("Fixed")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  allowanceOption AllowanceOption @relation(fields: [allowanceOptionId], references: [id], onDelete: Restrict)

  @@map("employee_allowance")
  @@index([employeeId])
}

model EmployeeCommission {
  id         String   @id @default(cuid())
  employeeId String
  title      String
  amount     Float    @default(0)
  type       String   @default("Fixed")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_commission")
  @@index([employeeId])
}

model LoanOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employeeLoans EmployeeLoan[]

  @@map("loan_option")
}

model EmployeeLoan {
  id          String    @id @default(cuid())
  employeeId  String
  loanOptionId String
  title       String
  amount      Float     @default(0)
  startDate   DateTime
  endDate     DateTime
  reason      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  loanOption LoanOption @relation(fields: [loanOptionId], references: [id], onDelete: Restrict)

  @@map("employee_loan")
  @@index([employeeId])
}

model DeductionOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employeeSaturationDeductions EmployeeSaturationDeduction[]

  @@map("deduction_option")
}

model EmployeeSaturationDeduction {
  id                String   @id @default(cuid())
  employeeId        String
  deductionOptionId String
  title             String
  amount            Float    @default(0)
