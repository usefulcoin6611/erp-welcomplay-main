// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  password      String?
  role          String   @default("employee") // super admin, company, client, employee
  branchId      String?
  departmentId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions         Session[]
  accounts         Account[]
  branch           Branch?     @relation(fields: [branchId], references: [id])
  department       Department? @relation(fields: [departmentId], references: [id])
  createdCustomers Customer[]  @relation("CreatedBy")
  createdVendors   Vendor[]
  employee         Employee?
  createdContracts Contract[]
  ownedLeads       Lead[]      @relation("LeadOwner")
  createdLeads     Lead[]      @relation("LeadCreatedBy")
  createdProjects  Project[]   @relation("UserCreatedProjects")

  @@map("user")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  departments     Department[]
  categories      Category[]
  chartOfAccounts ChartOfAccount[]
  journalEntries  JournalEntry[]
  customers       Customer[]
  vendors         Vendor[]
  bills           Bill[]
  products        Product[]
  expenses        Expense[]
  payments        Payment[]
  bankAccounts    BankAccount[]
  bankTransfers   BankTransfer[]
  financialGoals  FinancialGoal[]
  budgetPlans     BudgetPlan[]
  leads           Lead[]
  pipelines       Pipeline[]
  deals           Deal[]
  jobs            Job[]

  @@map("branch")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users        User[]
  designations Designation[]

  @@map("department")
}

model Designation {
  id           String   @id @default(cuid())
  name         String
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@map("designation")
}

model LeaveType {
  id          String   @id @default(cuid())
  name        String
  daysPerYear Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leaveRequests LeaveRequest[]

  @@map("leave_type")
}

model DocumentType {
  id                 String             @id @default(cuid())
  name               String
  requiredField      Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  employeeDocuments  EmployeeDocument[]

  @@map("document_type")
}

model PayslipType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payslips  Payslip[]

  @@map("payslip_type")
}

model GoalType {
  id               String           @id @default(cuid())
  name             String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  performanceGoals PerformanceGoal[]

  @@map("goal_type")
}

model TrainingType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("training_type")
}

model AwardType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("award_type")
}

model TerminationType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("termination_type")
}

model JobCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("job_category")
}

model RecruitmentQuestion {
  id         String        @id @default(cuid())
  question   String
  isRequired Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  jobQuestions JobQuestion[]

  @@map("recruitment_question")
}

model Job {
  id            String   @id @default(cuid())
  title         String
  branchId      String
  jobCategoryId String
  positions     Int      @default(1)
  status        String   @default("active") // active, in_active
  startDate     DateTime
  endDate       DateTime
  description   String?
  requirement   String?
  skill         Json?    // string[]
  applicant     Json?    // string[]
  visibility    Json?    // string[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch       Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  jobCategory  JobCategory      @relation(fields: [jobCategoryId], references: [id], onDelete: Restrict)
  jobQuestions JobQuestion[]
  applications JobApplication[]

  @@map("job")
}

model JobQuestion {
  jobId      String
  questionId String
  order      Int     @default(0)
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question   RecruitmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([jobId, questionId])
  @@map("job_question")
}

model JobApplication {
  id             String    @id @default(cuid())
  jobId          String
  stageId        String
  applicantName  String
  email          String
  phone          String
  appliedDate    DateTime
  rating         Int       @default(0) // 1-5
  resume         String?
  coverLetter    String?
  isArchive      Boolean   @default(false)
  dob            String?
  gender         String?
  country        String?
  state          String?
  city           String?
  profile        String?
  skill          String?
  customQuestion Json?     // Record<string, string>
  notes          Json?     // { id, note, createdAt, noteCreatedName }[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  job         Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage       JobStage              @relation(fields: [stageId], references: [id], onDelete: Restrict)
  interviews  RecruitmentInterview[]
  onboarding  JobOnboarding?

  @@map("job_application")
}

model RecruitmentInterview {
  id             String   @id @default(cuid())
  applicationId  String
  interviewDate  DateTime
  interviewTime  String   // e.g. "10:00"
  interviewer    String
  location       String
  status         String   @default("Scheduled") // Scheduled, Completed, Cancelled, Rescheduled
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("recruitment_interview")
}

model JobStage {
  id           String          @id @default(cuid())
  name         String
  order        Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  applications JobApplication[]

  @@map("job_stage")
}

/// Onboarding untuk kandidat yang sudah Hired. Link ke Application, optional ke Employee saat "convert to employee".
model JobOnboarding {
  id             String    @id @default(cuid())
  applicationId String    @unique
  employeeId    String?   @unique // di-set saat "convert to employee"
  status        String    @default("pending") // pending | in_progress | completed | converted
  onboardingDate DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employee    Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@map("job_onboarding")
}

model PerformanceType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("performance_type")
}

model Competency {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("competency")
}

/// Indikator performansi per branch/department/designation (rating teknis, organisasi, customer experience).
model PerformanceIndicator {
  id                      String   @id @default(cuid())
  branch                  String
  department              String
  designation             String
  technicalRating         Float
  organizationalRating    Float
  customerExperienceRating Float
  overallRating           Float
  addedBy                 String   @default("")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("performance_indicator")
}

/// Appraisal per karyawan: target rating, overall rating, sub-rating, tanggal, remarks.
model PerformanceAppraisal {
  id                  String    @id @default(cuid())
  employeeId          String
  branch              String
  department          String
  designation         String
  targetRating        Float
  overallRating       Float
  appraisalDate       DateTime
  technicalRating     Float?
  leadershipRating    Float?
  teamworkRating      Float?
  communicationRating Float?
  remarks             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("performance_appraisal")
}

/// Goal tracking: link ke GoalType, subject, branch, target, periode, rating, progress.
model PerformanceGoal {
  id                String   @id @default(cuid())
  goalTypeId        String
  subject           String
  branch            String
  targetAchievement String
  startDate         DateTime
  endDate           DateTime
  rating            Int      // 1-5
  progress          Int      // 0-100
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goalType GoalType @relation(fields: [goalTypeId], references: [id], onDelete: Restrict)

  @@map("performance_goal")
}

model Employee {
  id                   String             @id @default(cuid())
  employeeId           String             @unique
  name                 String
  email                String             @unique
  phone                String
  dateOfBirth          DateTime
  gender               String
  address              String
  branch               String
  department           String
  designation          String
  dateOfJoining        DateTime
  lastLogin            DateTime?
  isActive             Boolean            @default(true)
  salaryType           String?
  basicSalary          Float?
  documentsCertificate String?
  documentsPhoto       String?
  accountHolderName    String?
  accountNumber        String?
  bankName             String?
  bankIdentifierCode   String?
  branchLocation       String?
  taxPayerId           String?
  userId               String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  employeeDocuments    EmployeeDocument[]
  allowances           EmployeeAllowance[]
  commissions          EmployeeCommission[]
  loans                EmployeeLoan[]
  saturationDeductions EmployeeSaturationDeduction[]
  otherPayments        EmployeeOtherPayment[]
  overtimes            EmployeeOvertime[]
  payslips             Payslip[]
  leaves               LeaveRequest[]
  attendances          Attendance[]

  user                User?                 @relation(fields: [userId], references: [id])
  onboarding          JobOnboarding?
  performanceAppraisals PerformanceAppraisal[]

  @@map("employee")
}

model EmployeeDocument {
  id             String       @id @default(cuid())
  employeeId     String
  documentTypeId String
  filePath       String?
  fileName       String?
  mimeType       String?
  fileSize       Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, documentTypeId])
  @@map("employee_document")
}

model AllowanceOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employeeAllowances EmployeeAllowance[]

  @@map("allowance_option")
}

model LoanOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employeeLoans EmployeeLoan[]

  @@map("loan_option")
}

model DeductionOption {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employeeSaturationDeductions EmployeeSaturationDeduction[]

  @@map("deduction_option")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  type      String // Product & Service, Income, Expense
  account   String?
  color     String?  @default("FFFFFF")
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch?   @relation(fields: [branchId], references: [id])
  products Product[]
  bills    Bill[]

  @@map("category")
}

model Tax {
  id        String   @id @default(cuid())
  name      String
  rate      Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("tax")
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("unit")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  sku              String   @unique
  salePrice        Float    @default(0)
  purchasePrice    Float    @default(0)
  taxId            String?
  categoryId       String?
  unitId           String?
  quantity         Float    @default(0)
  type             String
  branchId         String?
  saleAccountId    String?
  expenseAccountId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category       Category?       @relation(fields: [categoryId], references: [id])
  unit           Unit?           @relation(fields: [unitId], references: [id])
  tax            Tax?            @relation(fields: [taxId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  saleAccount    ChartOfAccount? @relation("SaleAccount", fields: [saleAccountId], references: [id])
  expenseAccount ChartOfAccount? @relation("ExpenseAccount", fields: [expenseAccountId], references: [id])
  billItems      BillItem[]
  expenseItems   ExpenseItem[]

  @@map("product")
}

model CustomField {
  id        String   @id @default(cuid())
  name      String
  type      String
  module    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custom_field")
}

model ChartOfAccount {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  type         String // Assets, Liabilities, Equity, Income, Expense
  subType      String // e.g., Current Assets, Fixed Assets, etc.
  description  String?
  isSubAccount Boolean  @default(false)
  parentId     String?
  branchId     String?
  balance      Float    @default(0)
  status       String   @default("Active") // Active, Inactive
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch          Branch?          @relation(fields: [branchId], references: [id])
  parent          ChartOfAccount?  @relation("SubAccounts", fields: [parentId], references: [id])
  subAccounts     ChartOfAccount[] @relation("SubAccounts")
  journalLines    JournalLine[]
  saleProducts    Product[]        @relation("SaleAccount")
  expenseProducts Product[]        @relation("ExpenseAccount")
  bankAccounts    BankAccount[]

  @@map("chart_of_account")
}

model JournalEntry {
  id             String   @id @default(cuid())
  journalId      String   @unique // e.g., JR-2025-001
  date           DateTime
  description    String?
  reference      String?
  amount         Float
  paymentReceipt String?
  branchId       String?
  customerId     String?
  bankAccountId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch      Branch?       @relation(fields: [branchId], references: [id])
  customer    Customer?     @relation(fields: [customerId], references: [id])
  bankAccount BankAccount?  @relation(fields: [bankAccountId], references: [id])
  lines       JournalLine[]

  @@map("journal_entry")
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Float    @default(0)
  credit         Float    @default(0)
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@map("journal_line")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
}

model Customer {
  id              String   @id @default(cuid())
  customerCode    String   @unique
  name            String
  email           String   @unique
  contact         String?
  avatar          String?
  isActive        Boolean  @default(true)
  taxNumber       String?
  billingName     String?
  billingCountry  String?
  billingState    String?
  billingCity     String?
  billingPhone    String?
  billingZip      String?
  billingAddress  String?
  shippingName    String?
  shippingCountry String?
  shippingState   String?
  shippingCity    String?
  shippingPhone   String?
  shippingZip     String?
  shippingAddress String?
  balance         Float    @default(0)
  branchId        String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch         Branch?        @relation(fields: [branchId], references: [id])
  createdBy      User?          @relation("CreatedBy", fields: [createdById], references: [id])
  estimates      Estimate[]
  invoices       Invoice[]
  journalEntries JournalEntry[]

  @@map("customer")
}

model Vendor {
  id              String   @id @default(cuid())
  vendorCode      String   @unique
  name            String
  email           String   @unique
  contact         String?
  avatar          String?
  isActive        Boolean  @default(true)
  taxNumber       String?
  billingName     String?
  billingCountry  String?
  billingState    String?
  billingCity     String?
  billingPhone    String?
  billingZip      String?
  billingAddress  String?
  shippingName    String?
  shippingCountry String?
  shippingState   String?
  shippingCity    String?
  shippingPhone   String?
  shippingZip     String?
  shippingAddress String?
  balance         Float    @default(0)
  branchId        String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch    Branch? @relation(fields: [branchId], references: [id])
  createdBy User?   @relation(fields: [createdById], references: [id])
  bills     Bill[]

  @@map("vendor")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Estimate {
  id          String   @id @default(cuid())
  estimateId  String   @unique
  customerId  String
  categoryId  String?
  issueDate   DateTime
  status      Int      @default(0)
  total       Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer       @relation(fields: [customerId], references: [id])
  items    EstimateItem[]

  @@map("estimate")
}

model EstimateItem {
  id         String   @id @default(cuid())
  estimateId String
  itemName   String
  quantity   Float    @default(0)
  price      Float    @default(0)
  discount   Float    @default(0)
  taxRate    Float    @default(0)
  amount     Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_item")
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceId   String   @unique
  customerId  String
  categoryId  String?
  issueDate   DateTime
  dueDate     DateTime
  status      Int      @default(0) // 0 Draft, 1 Sent, 2 Unpaid, 3 Partial, 4 Paid
  dueAmount   Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer      @relation(fields: [customerId], references: [id])
  items       InvoiceItem[]
  creditNotes CreditNote[]

  @@map("invoice")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  itemName    String
  quantity    Float    @default(0)
  price       Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_item")
}

model CreditNote {
  id          String   @id @default(cuid())
  number      Int
  invoiceId   String
  date        DateTime
  amount      Float    @default(0)
  description String?
  status      Int      @default(0) // 0 Pending, 1 Partially Used, 2 Fully Used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [invoiceId])

  @@map("credit_note")
}

model DebitNote {
  id          String   @id @default(cuid())
  number      Int
  billId      String
  date        DateTime
  amount      Float    @default(0)
  description String?
  status      Int      @default(0) // 0 Pending, 1 Partially Used, 2 Fully Used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bill Bill @relation(fields: [billId], references: [billId])

  @@map("debit_note")
}

model Bill {
  id          String   @id @default(cuid())
  billId      String   @unique
  vendorId    String
  branchId    String?
  categoryId  String?
  billDate    DateTime
  dueDate     DateTime
  status      String   @default("draft")
  total       Float    @default(0)
  reference   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor     Vendor      @relation(fields: [vendorId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id])
  items      BillItem[]
  debitNotes DebitNote[]

  @@map("bill")
}

model BillItem {
  id          String   @id @default(cuid())
  billId      String
  productId   String?
  itemName    String
  quantity    Float    @default(0)
  price       Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bill    Bill     @relation(fields: [billId], references: [billId], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("bill_item")
}

model Expense {
  id             String   @id @default(cuid())
  expenseId      String   @unique
  type           String
  party          String
  date           DateTime
  category       String
  total          Float    @default(0)
  status         String   @default("Pending")
  reference      String?
  description    String?
  paymentReceipt String?
  branchId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch?       @relation(fields: [branchId], references: [id])
  items  ExpenseItem[]

  @@map("expense")
}

model ExpenseItem {
  id          String   @id @default(cuid())
  expenseId   String
  productId   String?
  itemName    String
  quantity    Float    @default(0)
  price       Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expense Expense  @relation(fields: [expenseId], references: [expenseId], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("expense_item")
}

model Payment {
  id             String   @id @default(cuid())
  paymentId      String   @unique
  date           DateTime
  vendor         String
  account        String
  category       String
  amount         Float    @default(0)
  status         String   @default("Completed")
  reference      String?
  description    String?
  paymentReceipt String?
  branchId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("payment")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("setting")
}

model BankTransfer {
  id            String   @id @default(cuid())
  branchId      String?
  fromAccountId String
  toAccountId   String
  date          DateTime
  amount        Float    @default(0)
  reference     String?
  description   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch      Branch?     @relation(fields: [branchId], references: [id])
  fromAccount BankAccount @relation("BankTransferFrom", fields: [fromAccountId], references: [id])
  toAccount   BankAccount @relation("BankTransferTo", fields: [toAccountId], references: [id])

  @@map("bank_transfer")
}

model BankAccount {
  id             String   @id @default(cuid())
  branchId       String?
  chartAccountId String
  holderName     String
  bank           String
  accountNumber  String
  openingBalance Float    @default(0)
  contactNumber  String?
  bankAddress    String?
  paymentGateway String
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch         Branch?        @relation(fields: [branchId], references: [id])
  chartAccount   ChartOfAccount @relation(fields: [chartAccountId], references: [id])
  transfersFrom  BankTransfer[] @relation("BankTransferFrom")
  transfersTo    BankTransfer[] @relation("BankTransferTo")
  journalEntries JournalEntry[]

  @@map("bank_account")
}

model FinancialGoal {
  id        String   @id @default(cuid())
  branchId  String?
  name      String
  type      String // Invoice, Bill, Revenue, Payment
  fromDate  DateTime
  toDate    DateTime
  amount    Float    @default(0)
  isDisplay Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("financial_goal")
}

model BudgetPlan {
  id        String   @id @default(cuid())
  branchId  String?
  name      String
  fromYear  Int
  period    String // Monthly, Quarterly, Half Yearly, Yearly
  details   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch?  @relation(fields: [branchId], references: [id])

  @@map("budget_plan")
}

model Contract {
  id                  String   @id @default(cuid())
  contractId          String   @unique
  clientName          String
  subject             String
  value               Float    @default(0)
  type                String
  startDate           DateTime
  endDate             DateTime
  description         String?
  status              String   @default("accept")
  contractDescription String?
  createdById         String?
  projectId           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])

  @@map("contract")
}

model ContractType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contract_type")
}

model Pipeline {
  id        String   @id @default(cuid())
  branchId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch     Branch?        @relation(fields: [branchId], references: [id])
  leadStages LeadStage[]
  leads      Lead[]
  deals      Deal[]
  dealStages DealStage[]
  labels     PipelineLabel[]

  @@map("pipeline")
}

model Source {
  id        String   @id @default(cuid())
  branchId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("source")
}

model LeadStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    Lead[]
  deals    Deal[]

  @@map("lead_stage")
}

model DealStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("deal_stage")
}

model Lead {
  id          String    @id @default(cuid())
  leadId      String    @unique
  branchId    String?
  name        String
  email       String?
  subject     String?
  phone       String?
  pipelineId  String?
  stageId     String?
  sources     String?
  products    String?
  notes       String?
  labels      String?
  order       Int?
  ownerId     String?
  createdById String?
  isActive    Boolean   @default(true)
  date        DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch    Branch?    @relation(fields: [branchId], references: [id])
  pipeline  Pipeline?  @relation(fields: [pipelineId], references: [id])
  stage     LeadStage? @relation(fields: [stageId], references: [id])
  owner     User?      @relation("LeadOwner", fields: [ownerId], references: [id])
  createdBy User?      @relation("LeadCreatedBy", fields: [createdById], references: [id])

  @@map("lead")
}

model Deal {
  id             String   @id @default(cuid())
  dealId         String   @unique
  branchId       String?
  name           String
  client         String?
  phone          String?
  price          Float    @default(0)
  pipelineId     String?
  stageId        String?
  status         String   @default("Open")
  isActive       Boolean  @default(true)
  tasksTotal     Int?     @default(0)
  tasksCompleted Int?     @default(0)
  productsCount  Int?     @default(0)
  sourcesCount   Int?     @default(0)
  labels         Json?
  users          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch   Branch?    @relation(fields: [branchId], references: [id])
  pipeline Pipeline?  @relation(fields: [pipelineId], references: [id])
  stage    LeadStage? @relation(fields: [stageId], references: [id])

  @@map("deal")
}

model PipelineLabel {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  color      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("pipeline_label")
}

model FormBuilder {
  id           String   @id @default(cuid())
  formId       String   @unique
  name         String
  code         String   @unique
  isActive     Boolean  @default(true)
  isLeadActive Boolean  @default(false)
  responses    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fields FormField[]

  @@map("form_builder")
}

model FormField {
  id        String   @id @default(cuid())
  formId    String
  name      String
  type      String
  required  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form FormBuilder @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_field")
}

model EmployeeAllowance {
  id                String          @id @default(cuid())
  employeeId        String
  allowanceOptionId String
  title             String
  amount            Float           @default(0)
  type              String          @default("Fixed") // Fixed or Percentage
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  allowanceOption AllowanceOption @relation(fields: [allowanceOptionId], references: [id])
  
  @@map("employee_allowance")
}

model EmployeeCommission {
  id         String   @id @default(cuid())
  employeeId String
  title      String
  amount     Float    @default(0)
  type       String   @default("Fixed") // Fixed or Percentage
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@map("employee_commission")
}

model EmployeeLoan {
  id           String   @id @default(cuid())
  employeeId   String
  loanOptionId String
  title        String
  amount       Float    @default(0)
  startDate    DateTime
  endDate      DateTime
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  loanOption LoanOption @relation(fields: [loanOptionId], references: [id])
  
  @@map("employee_loan")
}

model EmployeeSaturationDeduction {
  id                String          @id @default(cuid())
  employeeId        String
  deductionOptionId String
  title             String
  amount            Float           @default(0)
  type              String          @default("Fixed") // Fixed or Percentage
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  deductionOption DeductionOption @relation(fields: [deductionOptionId], references: [id])
  
  @@map("employee_saturation_deduction")
}

model EmployeeOtherPayment {
  id         String   @id @default(cuid())
  employeeId String
  title      String
  amount     Float    @default(0)
  type       String   @default("Fixed") // Fixed or Percentage
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@map("employee_other_payment")
}

model EmployeeOvertime {
  id         String   @id @default(cuid())
  employeeId String
  title      String
  days       Int      @default(0)
  hours      Int      @default(0)
  rate       Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@map("employee_overtime")
}

model Payslip {
  id             String   @id @default(cuid())
  employeeId     String
  payslipTypeId  String?
  salaryMonth    String   // YYYY-MM
  basicSalary    Float
  allowance      Float    @default(0)
  commission     Float    @default(0)
  loan           Float    @default(0)
  saturationDeduction Float @default(0)
  otherPayment   Float    @default(0)
  overtime       Float    @default(0)
  netSalary      Float
  status         Int      @default(0) // 0: Unpaid, 1: Paid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payslipType PayslipType? @relation(fields: [payslipTypeId], references: [id])
  
  @@map("payslip")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String   @default("Pending") // Pending, Approved, Rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
  
  @@map("leave_request")
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?
  status      String   @default("Present") // Present, Absent, Late, Half Day
  late        String?  // Duration
  earlyLeaving String? // Duration
  overtime    String?  // Duration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@unique([employeeId, date])
  
  @@map("attendance")
}

