  timeTrackers TimeTracker[]
  timesheets   Timesheet[]
  zoomMeetings ZoomMeeting[]

  @@map("project")
}

/// Zoom meeting (virtual meeting room). Optional link to Project; participants are Users.
model ZoomMeeting {
  id                 String                   @id @default(cuid())
  title              String
  projectId          String?
  startAt            DateTime
  durationMinutes    Int                      @default(60)
  joinUrl            String?
  startUrl           String?
  password           String?
  status             String                   @default("waiting")
  createdById        String
  syncGoogleCalendar Boolean                  @default(false)
  inviteClient       Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  createdBy          User                     @relation("ZoomMeetingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  project            Project?                 @relation(fields: [projectId], references: [id])
  participants       ZoomMeetingParticipant[]

  @@index([projectId])
  @@index([createdById])
  @@index([startAt])
  @@map("zoom_meeting")
}

model ZoomMeetingParticipant {
  id            String      @id @default(cuid())
  zoomMeetingId String
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  zoomMeeting   ZoomMeeting @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)

  @@unique([zoomMeetingId, userId])
  @@index([zoomMeetingId])
  @@index([userId])
  @@map("zoom_meeting_participant")
}

model ProjectTask {
  id           String        @id @default(cuid())
  taskKey      String        @unique
  projectId    String
  name         String
  description  String?
  priority     String
  stage        String
  startDate    DateTime?
  endDate      DateTime?
  estimatedHrs Float         @default(0)
  completion   Float         @default(0)
  attachments  Int           @default(0)
  comments     Int           @default(0)
  checklists   Int           @default(0)
  isOwner      Boolean       @default(false)
  assignedTo   Json?         @default("[]")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  project      Project       @relation(fields: [projectId], references: [projectId])
  timeTrackers TimeTracker[]
  timesheets   Timesheet[]

  @@map("project_task")
}

model Timesheet {
  id          String       @id @default(cuid())
  projectId   String
  taskId      String?
  date        DateTime
  minutes     Int
  userName    String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [projectId])
  task        ProjectTask? @relation(fields: [taskId], references: [id])

  @@map("timesheet")
}

model BugStatus {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bugs      Bug[]

  @@map("bug_status")
}

model Bug {
  id          String     @id @default(cuid())
  bugKey      String     @unique
  projectId   String
  title       String
  priority    String
  startDate   DateTime?
  dueDate     DateTime?
  description String?
  statusId    String?
  createdBy   String?
  assignedTo  Json?      @default("[]")
  attachments Int        @default(0)
  comments    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  project     Project    @relation(fields: [projectId], references: [projectId])
  status      BugStatus? @relation(fields: [statusId], references: [id])

  @@map("bug")
}

model TimeTracker {
  id           String       @id @default(cuid())
  projectId    String
  taskId       String?
  name         String
  isActive     Boolean      @default(false)
  isBillable   Boolean      @default(false)
  startTime    DateTime
  endTime      DateTime?
  totalSeconds Int          @default(0)
  userName     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  project      Project      @relation(fields: [projectId], references: [projectId])
  task         ProjectTask? @relation(fields: [taskId], references: [id])

  @@map("time_tracker")
}

model company_policies {
  id          Int       @id @default(autoincrement())
  branch      String
  title       String
  description String?
  attachment  String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model document_uploads {
  id          Int       @id @default(autoincrement())
  name        String
  document    String?
  role        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model ProjectTaskStage {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_task_stage")
}

/// POS Warehouse: lokasi stok untuk transaksi POS.
model Warehouse {
  id            String              @id @default(cuid())
  name          String
  address       String?
  phone         String?
  branchId      String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  posOrders     PosOrder[]
  branch        Branch?             @relation(fields: [branchId], references: [id])
  transfersFrom WarehouseTransfer[] @relation("TransferFrom")
  transfersTo   WarehouseTransfer[] @relation("TransferTo")

  @@index([branchId])
  @@map("warehouse")
}

/// POS Order: transaksi kasir POS.
model PosOrder {
  id          String         @id @default(cuid())
  posId       String         @unique
  customerId  String?
  warehouseId String?
  branchId    String?
  discount    Float          @default(0)
  subtotal    Float          @default(0)
  total       Float          @default(0)
  status      String         @default("completed")
  quotationId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  branch      Branch?        @relation(fields: [branchId], references: [id])
  customer    Customer?      @relation(fields: [customerId], references: [id])
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id])
  items       PosOrderItem[]

  @@index([branchId])
  @@index([customerId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("pos_order")
}

/// POS Order Item: item dalam transaksi POS.
model PosOrderItem {
  id         String   @id @default(cuid())
  posOrderId String
  productId  String?
  itemName   String
  sku        String?
  quantity   Float    @default(1)
  price      Float    @default(0)
  discount   Float    @default(0)
  taxRate    Float    @default(0)
  subtotal   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  posOrder   PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id])

  @@index([posOrderId])
  @@map("pos_order_item")
}

/// POS Barcode Setting: konfigurasi barcode per branch.
model BarcodeSetting {
  id            String   @id @default(cuid())
  branchId      String?
  barcodeType   String   @default("code128")
  barcodeFormat String   @default("css")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch?  @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("barcode_setting")
}

/// Warehouse Transfer: transfer produk antar warehouse.
model WarehouseTransfer {
  id              String    @id @default(cuid())
  transferId      String    @unique
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  quantity        Float     @default(0)
  note            String?
  branchId        String?
  transferDate    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  branch          Branch?   @relation(fields: [branchId], references: [id])
  fromWarehouse   Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  product         Product   @relation("TransferProduct", fields: [productId], references: [id])
  toWarehouse     Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])

  @@index([branchId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([productId])
  @@index([transferDate])
  @@map("warehouse_transfer")
}

/// Subscription Plan model for SaaS plan management
model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  price        Float    @default(0)
  duration     String   @default("month")
  maxUsers     Int      @default(5)
  maxCustomers Int      @default(5)
  maxVenders   Int      @default(5)
  maxClients   Int      @default(5)
  storageLimit Int      @default(1024)
  trialDays    Int      @default(0)
  isDisable    Boolean  @default(false)
  hasAccount   Boolean  @default(true)
  hasCrm       Boolean  @default(true)
  hasHrm       Boolean  @default(true)
  hasProject   Boolean  @default(false)
  hasPos       Boolean  @default(false)
  hasChatgpt   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("plan")
}

/// Coupon/Discount code model for subscription plan discounts
model Coupon {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  discount  Float    @default(0)
  limit     Int      @default(0)
  used      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupon")
}

/// Subscription Order: records of plan purchases by companies (super admin view)
model Order {
  id             String   @id @default(cuid())
  orderId        String   @unique
  userId         String?
  userName       String
  planName       String
  price          Float    @default(0)
  paymentStatus  String   @default("Pending")
  paymentType    String   @default("Bank Transfer")
  coupon         String?
  receipt        String?
  isRefund       Int      @default(0)
  orderDate      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  paymentDetails Json?
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([paymentStatus])
  @@index([orderDate])
  @@map("order")
}

model hrm_asset_employees {
  id          Int        @id @default(autoincrement())
  asset_id    Int
  employee_id String
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @default(now()) @db.Timestamptz(6)
  hrm_assets  hrm_assets @relation(fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employee    Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([asset_id, employee_id])
}

model hrm_assets {
  id                  Int                   @id @default(autoincrement())
  name                String
  purchase_date       DateTime?             @db.Date
  supported_date      DateTime?             @db.Date
  amount              Decimal               @default(0) @db.Decimal(18, 2)
  description         String?
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  hrm_asset_employees hrm_asset_employees[]
}
