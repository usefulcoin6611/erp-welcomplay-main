model AccessProfile {
  id          String   @id @default(cuid())
  name        String
  branchId    String
  permissions Json     @default("[]")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  users       User[]

  @@index([branchId])
  @@map("access_profile")
}

model Branch {
  id                   String                @id @default(cuid())
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  address              String?
  email                String?
  logo                 String?
  phone                String?
  website              String?
  ownerId              String?
  accessProfiles       AccessProfile[]
  bankAccounts         BankAccount[]
  bankTransfers        BankTransfer[]
  barcodeSettings      BarcodeSetting[]
  bill                 Bill[]
  budgetPlans          BudgetPlan[]
  categories           Category[]
  chartOfAccounts      ChartOfAccount[]
  customers            Customer[]
  deals                Deal[]
  departments          Department[]
  estimates            Estimate[]
  expenses             Expense[]
  financialGoals       FinancialGoal[]
  jobs                 Job[]
  journalEntries       JournalEntry[]
  leads                Lead[]
  payments             Payment[]
  payoutRequests       PayoutRequest[]       @relation("BranchPayouts")
  pipelines            Pipeline[]
  posOrders            PosOrder[]
  products             Product[]
  referralTransactions ReferralTransaction[] @relation("ReferrerTransactions")
  sources              Source[]
  users                User[]
  vendors              Vendor[]
  warehouses           Warehouse[]
  warehouseTransfers   WarehouseTransfer[]
  projects             Project[]
  bugStatuses          BugStatus[]
  projectTaskStages    ProjectTaskStage[]
  contracts            Contract[]
  contractTypes        ContractType[]
  formBuilders         FormBuilder[]
  invoices             Invoice[]
  taxes                Tax[]
  units                Unit[]

  @@map("branch")
}

model Department {
  id           String        @id @default(cuid())
  name         String
  branchId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  designations Designation[]
  users        User[]

  @@map("department")
}

model Designation {
  id            String         @id @default(cuid())
  name          String
  departmentId  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  hrmPromotions HrmPromotion[]

  @@map("designation")
}

model Setting {
  id        String   @id @default(cuid())
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
  @@map("setting")
}

model CustomField {
  id        String   @id @default(cuid())
  name      String
  type      String
  module    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custom_field")
}

model company_policies {
  id          Int       @id @default(autoincrement())
  branch      String
  title       String
  description String?
  attachment  String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model document_uploads {
  id          Int       @id @default(autoincrement())
  name        String
  document    String?
  role        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}
