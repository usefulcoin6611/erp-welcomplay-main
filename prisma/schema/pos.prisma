model Warehouse {
  id            String              @id @default(cuid())
  name          String
  address       String?
  phone         String?
  branchId      String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  posOrders     PosOrder[]
  branch        Branch?             @relation(fields: [branchId], references: [id])
  transfersFrom WarehouseTransfer[] @relation("TransferFrom")
  transfersTo   WarehouseTransfer[] @relation("TransferTo")

  @@index([branchId])
  @@map("warehouse")
}

model PosOrder {
  id          String         @id @default(cuid())
  posId       String         @unique
  customerId  String?
  warehouseId String?
  branchId    String?
  discount    Float          @default(0)
  subtotal    Float          @default(0)
  total       Float          @default(0)
  status      String         @default("completed")
  quotationId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  branch      Branch?        @relation(fields: [branchId], references: [id])
  customer    Customer?      @relation(fields: [customerId], references: [id])
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id])
  items       PosOrderItem[]

  @@index([branchId])
  @@index([customerId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("pos_order")
}

model PosOrderItem {
  id         String   @id @default(cuid())
  posOrderId String
  productId  String?
  itemName   String
  sku        String?
  quantity   Float    @default(1)
  price      Float    @default(0)
  discount   Float    @default(0)
  taxRate    Float    @default(0)
  subtotal   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  posOrder   PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id])

  @@index([posOrderId])
  @@map("pos_order_item")
}

model BarcodeSetting {
  id            String   @id @default(cuid())
  branchId      String?
  barcodeType   String   @default("code128")
  barcodeFormat String   @default("css")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch?  @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("barcode_setting")
}

model WarehouseTransfer {
  id              String    @id @default(cuid())
  transferId      String    @unique
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  quantity        Float     @default(0)
  note            String?
  branchId        String?
  transferDate    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  branch          Branch?   @relation(fields: [branchId], references: [id])
  fromWarehouse   Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  product         Product   @relation("TransferProduct", fields: [productId], references: [id])
  toWarehouse     Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])

  @@index([branchId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([productId])
  @@index([transferDate])
  @@map("warehouse_transfer")
}
