model Product {
  id                 String              @id @default(cuid())
  name               String
  sku                String              @unique
  salePrice          Float               @default(0)
  purchasePrice      Float               @default(0)
  taxId              String?
  categoryId         String?
  unitId             String?
  quantity           Float               @default(0)
  type               String
  branchId           String?
  saleAccountId      String?
  expenseAccountId   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  billItems          BillItem[]
  expenseItems       ExpenseItem[]
  posOrderItems      PosOrderItem[]
  branch             Branch?             @relation(fields: [branchId], references: [id])
  category           Category?           @relation(fields: [categoryId], references: [id])
  expenseAccount     ChartOfAccount?     @relation("ExpenseAccount", fields: [expenseAccountId], references: [id])
  saleAccount        ChartOfAccount?     @relation("SaleAccount", fields: [saleAccountId], references: [id])
  tax                Tax?                @relation(fields: [taxId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  warehouseTransfers WarehouseTransfer[] @relation("TransferProduct")

  @@map("product")
}

model Customer {
  id              String         @id @default(cuid())
  customerCode    String         @unique
  name            String
  email           String         @unique
  contact         String?
  taxNumber       String?
  balance         Float          @default(0)
  billingName     String?
  billingPhone    String?
  billingAddress  String?
  billingCity     String?
  billingState    String?
  billingCountry  String?
  billingZip      String?
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingCountry String?
  shippingZip     String?
  branchId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  avatar          String?
  createdById     String?
  isActive        Boolean        @default(true)
  branch          Branch?        @relation(fields: [branchId], references: [id])
  createdBy       User?          @relation("CreatedBy", fields: [createdById], references: [id])
  estimates       Estimate[]
  invoices        Invoice[]
  journalEntries  JournalEntry[]
  posOrders       PosOrder[]

  @@map("customer")
}

model Vendor {
  id              String   @id @default(cuid())
  vendorCode      String   @unique
  name            String
  email           String   @unique
  contact         String?
  avatar          String?
  isActive        Boolean  @default(true)
  taxNumber       String?
  billingName     String?
  billingCountry  String?
  billingState    String?
  billingCity     String?
  billingPhone    String?
  billingZip      String?
  billingAddress  String?
  shippingName    String?
  shippingCountry String?
  shippingState   String?
  shippingCity    String?
  shippingPhone   String?
  shippingZip     String?
  shippingAddress String?
  balance         Float    @default(0)
  branchId        String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bills           Bill[]
  branch          Branch?  @relation(fields: [branchId], references: [id])
  createdBy       User?    @relation(fields: [createdById], references: [id])

  @@map("vendor")
}

model Estimate {
  id          String         @id @default(cuid())
  estimateId  String         @unique
  customerId  String
  categoryId  String?
  issueDate   DateTime
  status      Int            @default(0)
  total       Float          @default(0)
  description String?
  branchId    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  branch      Branch?        @relation(fields: [branchId], references: [id])
  customer    Customer       @relation(fields: [customerId], references: [id])
  items       EstimateItem[]

  @@index([branchId])
  @@map("estimate")
}

model EstimateItem {
  id         String   @id @default(cuid())
  estimateId String
  itemName   String
  quantity   Float    @default(0)
  price      Float    @default(0)
  discount   Float    @default(0)
  taxRate    Float    @default(0)
  amount     Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_item")
}

model Invoice {
  id          String        @id @default(cuid())
  issueDate   DateTime
  dueDate     DateTime
  customerId  String
  categoryId  String?
  description String?
  status      Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  dueAmount   Float         @default(0)
  invoiceId   String        @unique
  creditNotes CreditNote[]
  customer    Customer      @relation(fields: [customerId], references: [id])
  items       InvoiceItem[]

  @@map("invoice")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  quantity    Float    @default(0)
  price       Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  itemName    String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_item")
}

model CreditNote {
  id          String   @id @default(cuid())
  invoiceId   String
  date        DateTime
  amount      Float    @default(0)
  description String?
  status      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  number      Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [invoiceId])

  @@map("credit_note")
}

model DebitNote {
  id          String   @id @default(cuid())
  number      Int
  billId      String
  date        DateTime
  amount      Float    @default(0)
  description String?
  status      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bill        Bill     @relation(fields: [billId], references: [billId])

  @@map("debit_note")
}

model Bill {
  id          String      @id @default(cuid())
  billId      String      @unique
  vendorId    String
  branchId    String?
  categoryId  String?
  billDate    DateTime
  dueDate     DateTime
  status      String      @default("draft")
  total       Float       @default(0)
  reference   String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  branch      Branch?     @relation(fields: [branchId], references: [id])
  category    Category?   @relation(fields: [categoryId], references: [id])
  vendor      Vendor      @relation(fields: [vendorId], references: [id])
  items       BillItem[]
  debitNotes  DebitNote[]

  @@map("bill")
}

model BillItem {
  id          String   @id @default(cuid())
  billId      String
  itemName    String
  quantity    Float    @default(0)
  price       Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  productId   String?
  bill        Bill     @relation(fields: [billId], references: [billId], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("bill_item")
}

model Expense {
  id             String        @id @default(cuid())
  expenseId      String        @unique
  type           String
  party          String
  date           DateTime
  category       String
  total          Float         @default(0)
  status         String        @default("Pending")
  reference      String?
  description    String?
  paymentReceipt String?
  branchId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  branch         Branch?       @relation(fields: [branchId], references: [id])
  items          ExpenseItem[]

  @@map("expense")
}

model ExpenseItem {
  id          String   @id @default(cuid())
  expenseId   String
  productId   String?
  itemName    String
  quantity    Float    @default(0)
  price       Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float    @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expense     Expense  @relation(fields: [expenseId], references: [expenseId], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("expense_item")
}

model Payment {
  id             String   @id @default(cuid())
  paymentId      String   @unique
  date           DateTime
  vendor         String
  account        String
  category       String
  amount         Float    @default(0)
  status         String   @default("Completed")
  reference      String?
  description    String?
  paymentReceipt String?
  branchId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  branch         Branch?  @relation(fields: [branchId], references: [id])

  @@map("payment")
}
