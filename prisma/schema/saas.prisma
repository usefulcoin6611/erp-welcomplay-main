model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  price        Float    @default(0)
  duration     String   @default("month")
  maxUsers     Int      @default(5)
  maxCustomers Int      @default(5)
  maxVenders   Int      @default(5)
  maxClients   Int      @default(5)
  storageLimit Int      @default(1024)
  trialDays    Int      @default(0)
  isDisable    Boolean  @default(false)
  hasAccount   Boolean  @default(true)
  hasCrm       Boolean  @default(true)
  hasHrm       Boolean  @default(true)
  hasProject   Boolean  @default(false)
  hasPos       Boolean  @default(false)
  hasChatgpt   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("plan")
}

model Coupon {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  discount  Float    @default(0)
  limit     Int      @default(0)
  used      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupon")
}

model Order {
  id             String   @id @default(cuid())
  orderId        String   @unique
  userId         String?
  userName       String
  planName       String
  price          Float    @default(0)
  paymentStatus  String   @default("Pending")
  paymentType    String   @default("Bank Transfer")
  coupon         String?
  receipt        String?
  isRefund       Int      @default(0)
  orderDate      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  paymentDetails Json?
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([paymentStatus])
  @@index([orderDate])
  @@map("order")
}

model ReferralTransaction {
  id                 String   @id @default(cuid())
  referrerBranchId   String
  refereeCompanyName String
  planName           String
  planPrice          Float
  commissionPercent  Float
  commissionAmount   Float
  date               DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  referrerBranch     Branch   @relation("ReferrerTransactions", fields: [referrerBranchId], references: [id])

  @@map("referral_transaction")
}

model PayoutRequest {
  id              String   @id @default(cuid())
  branchId        String
  companyName     String
  requestedDate   DateTime @default(now())
  requestedAmount Float
  status          String   @default("In Progress")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  branch          Branch   @relation("BranchPayouts", fields: [branchId], references: [id])

  @@map("payout_request")
}

model ReferralSetting {
  id               String   @id @default(cuid())
  isEnable         Boolean  @default(true)
  percentage       Float    @default(10)
  minimumThreshold Float    @default(50000)
  guideline        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("referral_setting")
}
