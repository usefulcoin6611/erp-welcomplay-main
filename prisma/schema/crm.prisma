model Contract {
  id                  String   @id @default(cuid())
  contractId          String   @unique
  clientName          String
  subject             String
  value               Float    @default(0)
  type                String
  startDate           DateTime
  endDate             DateTime
  description         String?
  status              String   @default("accept")
  contractDescription String?
  createdById         String?
  projectId           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           User?    @relation(fields: [createdById], references: [id])

  @@map("contract")
}

model Pipeline {
  id             String          @id @default(cuid())
  branchId       String?
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deals          Deal[]
  dealStages     DealStage[]
  leads          Lead[]
  leadStages     LeadStage[]
  branch         Branch?         @relation(fields: [branchId], references: [id])
  pipelineLabels PipelineLabel[]

  @@map("pipeline")
}

model PipelineLabel {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  color      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, name])
  @@index([pipelineId])
  @@map("pipeline_label")
}

model ContractType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("contract_type")
}

model LeadStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deals      Deal[]
  leads      Lead[]
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("lead_stage")
}

model DealStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("deal_stage")
}

model Source {
  id        String   @id @default(cuid())
  name      String
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("source")
}

model Lead {
  id          String     @id @default(cuid())
  leadId      String     @unique
  branchId    String?
  name        String
  email       String?
  subject     String?
  phone       String?
  pipelineId  String?
  stageId     String?
  sources     String?
  products    String?
  notes       String?
  labels      String?
  order       Int?
  ownerId     String?
  createdById String?
  isActive    Boolean    @default(true)
  date        DateTime?  @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  branch      Branch?    @relation(fields: [branchId], references: [id])
  createdBy   User?      @relation("LeadCreatedBy", fields: [createdById], references: [id])
  owner       User?      @relation("LeadOwner", fields: [ownerId], references: [id])
  pipeline    Pipeline?  @relation(fields: [pipelineId], references: [id])
  stage       LeadStage? @relation(fields: [stageId], references: [id])

  @@map("lead")
}

model Deal {
  id             String     @id @default(cuid())
  dealId         String     @unique
  branchId       String?
  name           String
  client         String?
  price          Float      @default(0)
  pipelineId     String?
  stageId        String?
  status         String     @default("Open")
  isActive       Boolean    @default(true)
  tasksTotal     Int?       @default(0)
  tasksCompleted Int?       @default(0)
  productsCount  Int?       @default(0)
  sourcesCount   Int?       @default(0)
  labels         Json?
  users          Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  phone          String?
  branch         Branch?    @relation(fields: [branchId], references: [id])
  pipeline       Pipeline?  @relation(fields: [pipelineId], references: [id])
  stage          LeadStage? @relation(fields: [stageId], references: [id])

  @@map("deal")
}

model FormBuilder {
  id           String      @id @default(cuid())
  formId       String      @unique
  name         String
  code         String      @unique
  isActive     Boolean     @default(true)
  isLeadActive Boolean     @default(false)
  responses    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  fields       FormField[]

  @@map("form_builder")
}

model FormField {
  id        String      @id @default(cuid())
  formId    String
  name      String
  type      String
  required  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  form      FormBuilder @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_field")
}
